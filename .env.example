# SMTP-Zugangsdaten für den Kontaktformular-Versand (/api/contact)
# -----------------------------------------------------------------------------
# Lokal testen: diese Datei nach ".env" kopieren, Werte eintragen und mit
#   vercel dev
# starten (nur `vite` führt die /api-Funktion NICHT aus).
# Produktiv: dieselben Variablen bei Vercel als Environment Variables hinterlegen
# (Project → Settings → Environment Variables). .env wird NICHT committet.

SMTP_HOST=smtp.euer-hoster.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@manus-therapie.de
SMTP_PASS=
KONTAKT_EMPFAENGER=info@manus-therapie.de
SMTP_FROM=info@manus-therapie.de
